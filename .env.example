# Groq — LLM extraction + agent (free tier at console.groq.com)
GROQ_API_KEY=""
# openai/gpt-oss-120b: json_schema strict structured outputs + tool use (see docs/best-practices/groq-llm-api.md)
GROQ_MODEL="openai/gpt-oss-120b"

# Neon Postgres (neon.tech). Pooled URL for app queries; unpooled (host without "-pooler") for drizzle-kit migrations.
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# Inngest (app.inngest.com). Event key for sending events; signing key only needed in deployed environments.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# Set to 1 for local development so the v4 client targets the local Dev Server
# (npm run inngest:dev) instead of Inngest Cloud. Leave unset/empty in production.
INNGEST_DEV="1"

# Upstash Redis — rate limiting AI endpoints (console.upstash.com)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Gate for admin surfaces (Pipeline, Settings)
ADMIN_PASSWORD=""
